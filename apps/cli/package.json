{
  "name": "lfc-cli",
  "version": "0.1.0",
  "description": "LFC CLI — sync AI tool configs from your org",
  "type": "module",
  "bin": {
    "lfc": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "echo 'Use: pnpm lfc sync --dry-run'",
    "build": "tsc",
    "lfc": "tsx src/index.ts",
    "lint": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "lfc",
    "config",
    "ai",
    "claude",
    "cursor",
    "mcp"
  ],
  "author": "Abrega Inc",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AbregaInc/lfc-dev.git",
    "directory": "apps/cli"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3"
  }
}
