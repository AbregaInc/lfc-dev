{
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "LFC",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": true
    },
    "bundle": {
      "active": true,
      "identifier": "dev.lfc.tray",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "macOS": {
        "minimumSystemVersion": "10.15"
      },
      "windows": {
        "wix": {
          "language": "en-US"
        }
      }
    },
    "updater": {
      "active": false
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "LFC - Looking For Config",
        "width": 380,
        "height": 500,
        "resizable": false,
        "visible": false,
        "decorations": true
      }
    ],
    "systemTray": {
      "iconPath": "icons/tray-icon.png",
      "iconAsTemplate": true,
      "title": "LFC"
    }
  }
}
